def normalize_key(s: str) -> str:
    """
    Normalize the first-column key:
    - Keep original case & extension (exact-match semantics)
    - Trim spaces
    - Remove blanks and exact 'Total Done'
    """
    if s is None:
        return ""
    s = str(s).strip()
    if s == "" or s == "Total Done":
        return ""
    return s

def read_one(path: str) -> pd.DataFrame:
    """
    Read a contributor CSV defensively, normalize first column to `file_name`,
    drop blanks/'Total Done', drop unnamed/empty columns, deduplicate on `file_name`.
    """
    df = pd.read_csv(
        path,
        dtype=str,
        encoding="utf-8-sig",
        engine="python",
        sep=None,                  # auto-detect
        keep_default_na=False,
        na_filter=False
    )

    cols = [str(c).strip() for c in df.columns]
    if not cols:
        return pd.DataFrame(columns=["file_name"])
    cols[0] = "file_name"
    df.columns = cols

    df["file_name"] = df["file_name"].fillna("").astype(str).map(normalize_key)
    df = df[df["file_name"] != ""]

    # Drop junk/empty columns
    drop_cols = [c for c in df.columns if c.lower().startswith("unnamed:")]
    if drop_cols:
        df = df.drop(columns=drop_cols)
    df = df.dropna(axis=1, how="all")

    # Deduplicate by file_name (first occurrence wins)
    df = df.drop_duplicates(subset=["file_name"], keep="first")
    return df

def export_presence_matrix(merged: pd.DataFrame):
    """
    Build a boolean matrix: rows = merged file_name, columns = each CSV,
    value = whether that file_name appears in the CSV.
    """
    presence = pd.DataFrame({"file_name": merged["file_name"]})
    for fname in CSV_FILES:
        dfk = read_one(os.path.join(INPUT_DIR, fname))[["file_name"]]
        col = os.path.splitext(os.path.basename(fname))[0]
        presence[col] = presence["file_name"].isin(dfk["file_name"])
    out_path = os.path.join(INPUT_DIR, "presence_matrix.csv")
    presence.to_csv(out_path, index=False)
    print(f"📄 Exported presence_matrix.csv → {out_path}")

def main():
    # Existence checks (warn only)
    for fname in CSV_FILES:
        p = Path(INPUT_DIR) / fname
        if not p.exists():
            print(f"Missing file: {p}")

    # Merge step-by-step
    merged = read_one(os.path.join(INPUT_DIR, CSV_FILES[0]))
    for fname in CSV_FILES[1:]:
        df = read_one(os.path.join(INPUT_DIR, fname))
        # Only merge new columns to avoid overwriting existing ones
        new_cols = [c for c in df.columns if c != "file_name" and c not in merged.columns]
        df = df[["file_name"] + new_cols] if new_cols else df[["file_name"]]
        merged = pd.merge(merged, df, on="file_name", how=JOIN_MODE)

    # Sort by file_name for stable output
    merged = merged.sort_values("file_name").reset_index(drop=True)

    # Enforce desired column order
    cols_in_data = list(merged.columns)
    final_order = [c for c in DESIRED_ORDER if c in cols_in_data] + [c for c in cols_in_data if c not in DESIRED_ORDER]
    merged = merged[final_order]

    # Export
    merged.to_csv(OUTPUT_FILE, index=False)
    print(f"Exported merged CSV: {OUTPUT_FILE}")
    print(f"Merged shape: {merged.shape[0]} rows × {merged.shape[1]} cols")

    # Sanity check on row count
    if EXPECTED_ROWS and EXPECTED_ROWS > 0:
        if merged.shape[0] != EXPECTED_ROWS:
            print(f"Row count {merged.shape[0]} ≠ expected {EXPECTED_ROWS}. Exporting presence_matrix.csv for diagnostics.")
            export_presence_matrix(merged)
        else:
            print("Row count matches expected.")

if __name__ == "__main__":
    main()
