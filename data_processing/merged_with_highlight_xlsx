# -------------------- Helpers --------------------

_video_ext_re = re.compile(r"\.(mp4|mov|avi|mkv|m4v)$", flags=re.IGNORECASE)

def build_join_key(s: str) -> str:
    """
    Build a robust alignment key from file_name:
    - strip spaces → lowercase → strip common video extensions
    """
    if s is None:
        return ""
    s = str(s).strip().lower()
    s = _video_ext_re.sub("", s)
    return s

def read_csv_clean(path: str, is_base=False) -> pd.DataFrame:
    """
    Read CSV defensively, normalize first column to `file_name`, build join_key.
    Drop blank / 'Total Done' rows; drop empty columns; deduplicate on join_key.
    """
    df = pd.read_csv(
        path,
        dtype=str,
        encoding="utf-8-sig",
        engine="python",
        sep=None,                 # auto-detect
        keep_default_na=False,
        na_filter=False
    )

    cols = [str(c).strip() for c in df.columns]
    if not cols:
        return pd.DataFrame(columns=["file_name", "join_key"])

    # Normalize first column to file_name
    cols[0] = "file_name"
    df.columns = cols

    df["file_name"] = df["file_name"].fillna("").astype(str).str.strip()
    df = df[~df["file_name"].isin(["", "Total Done"])]

    # Join key
    df["join_key"] = df["file_name"].map(build_join_key)
    df = df[df["join_key"] != ""]

    # Drop junk columns / empty columns
    drop_cols = [c for c in df.columns if str(c).lower().startswith("unnamed:")]
    if drop_cols:
        df = df.drop(columns=drop_cols)
    df = df.dropna(axis=1, how="all")

    # Deduplicate by join_key (keep first)
    df = df.drop_duplicates(subset=["join_key"], keep="first")

    if is_base:
        # Keep file_name visible at front for base
        return df[["file_name", "join_key"] + [c for c in df.columns if c not in ("file_name", "join_key")]]
    else:
        # For subsequent merges, hide file_name to avoid collisions
        return df[["join_key"] + [c for c in df.columns if c not in ("file_name", "join_key")]]

def cell_is_yellow(cell) -> bool:
    """
    Determine if an openpyxl cell has a solid yellow fill (covering common yellows).
    """
    fill = cell.fill
    if not fill or not fill.patternType or str(fill.patternType).lower() != "solid":
        return False
    c = fill.start_color
    rgb = str(getattr(c, "rgb", "") or "").upper()
    common_yellows = {"FFFFFF00", "FFFF00", "FFFFE699", "FFFFF200", "FFFEFF00"}
    if rgb in common_yellows:
        return True
    indexed = getattr(c, "indexed", None)
    if indexed in (5, 6, 13, 19, 27, 45):
        return True
    return False

def extract_yellow_positions_from_xlsx(path: str):
    """
    Read the active sheet of an XLSX and return a set of (join_key, column_name)
    for cells that are yellow. Column 1 must be the file_name column.
    """
    full_path = Path(path)
    if not full_path.exists():
        return set()

    wb = load_workbook(str(full_path), data_only=True)
    ws = wb.active

    # Headers
    headers = []
    for c in ws[1]:
        headers.append(str(c.value).strip() if c.value is not None else "")
    if not headers:
        return set()
    headers[0] = "file_name"

    yellow = set()

    # Scan data rows
    for r in range(2, ws.max_row + 1):
        v = ws.cell(row=r, column=1).value
        s = "" if v is None else str(v).strip()
        if s in ("", "Total Done"):
            continue
        jk = build_join_key(s)
        if jk == "":
            continue

        # Columns start at 2 (col 1 is file_name)
        for c in range(2, min(ws.max_column, len(headers)) + 1):
            colname = headers[c - 1]
            if not colname or str(colname).lower().startswith("unnamed:"):
                continue
            cell = ws.cell(row=r, column=c)
            if cell_is_yellow(cell):
                yellow.add((jk, colname))

    wb.close()
    return yellow

# -------------------- Main --------------------

def main():
    # 0) existence checks
    for f in CSV_FILES + XLSX_FILES:
        p = Path(INPUT_DIR) / f
        if not p.exists():
            print(f"⚠️ Missing file: {p}")
    if len(CSV_FILES) != len(XLSX_FILES):
        print("⚠️ CSV_FILES and XLSX_FILES have different counts. Proceeding anyway, but some highlights may be missing.")

    # 1) Merge CSVs using join_key
    base_csv = os.path.join(INPUT_DIR, CSV_FILES[0])
    merged = read_csv_clean(base_csv, is_base=True)

    for fname in CSV_FILES[1:]:
        df = read_csv_clean(os.path.join(INPUT_DIR, fname), is_base=False)
        # Only merge in new columns to avoid overwriting existing ones
        new_cols = [c for c in df.columns if c != "join_key" and c not in merged.columns]
        df = df[["join_key"] + new_cols] if new_cols else df[["join_key"]]
        merged = pd.merge(merged, df, on="join_key", how=JOIN_MODE)

    # 2) Collect yellow cells from all XLSX files (union rule)
    yellow_positions = set()
    for xname in XLSX_FILES:
        yp = extract_yellow_positions_from_xlsx(os.path.join(INPUT_DIR, xname))
        yellow_positions |= yp

    # 3) Finalize columns (drop join_key, enforce DESIRED_ORDER, stable sort)
    merged = merged.drop(columns=["join_key"])
    cols_in_data = list(merged.columns)
    final_order = [c for c in DESIRED_ORDER if c in cols_in_data] + [c for c in cols_in_data if c not in DESIRED_ORDER]
    merged = merged[final_order]
    if "file_name" in merged.columns:
        merged = merged.sort_values("file_name").reset_index(drop=True)

    # 4) Write CSV (no formatting)
    merged.to_csv(OUTPUT_CSV, index=False)

    # 5) Write XLSX with yellow fills via openpyxl
    wb = Workbook()
    ws = wb.active
    ws.title = "merged"

    # Headers
    for j, col in enumerate(merged.columns, start=1):
        ws.cell(row=1, column=j, value=col)

    # Data
    for i in range(len(merged)):
        for j, col in enumerate(merged.columns, start=1):
            v = merged.iloc[i, j - 1]
            ws.cell(row=i + 2, column=j, value=None if pd.isna(v) else v)

    # Yellow style
    yellow_fill = PatternFill(fill_type="solid", start_color="FFFF00", end_color="FFFF00")

    # Map join_key from output file_name (build just-in-time)
    if "file_name" in merged.columns:
        out_join_keys = merged["file_name"].map(build_join_key).tolist()
        jk_to_row = {jk: (idx + 2) for idx, jk in enumerate(out_join_keys)}  # Excel rows start at 2
    else:
        jk_to_row = {}

    # Column name -> column index
    col_to_idx = {col: idx + 1 for idx, col in enumerate(merged.columns)}

    # Apply fills
    for (jk, colname) in yellow_positions:
        r = jk_to_row.get(jk, None)
        c = col_to_idx.get(colname, None)
        if r is not None and c is not None:
            ws.cell(row=r, column=c).fill = yellow_fill

    wb.save(OUTPUT_XLSX)

    # 6) Console report
    print(f"🎉 Outputs:\n - {OUTPUT_XLSX} (with yellow highlights)\n - {OUTPUT_CSV} (data only)")
    print(f"Merged shape: {merged.shape[0]} rows × {merged.shape[1]} cols")
    if JOIN_MODE in ("inner", "right") and EXPECTED_ROWS:
        if merged.shape[0] != EXPECTED_ROWS:
            print(f"⚠️ Row count {merged.shape[0]} ≠ expected {EXPECTED_ROWS}. "
                  f"To force {EXPECTED_ROWS} rows, set JOIN_MODE='right' and ensure the base CSV is CSV_FILES[0].")
        else:
            print("✅ Row count matches expected.")

if __name__ == "__main__":
    main()
